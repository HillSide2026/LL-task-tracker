<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" exporter="Camunda Modeler" exporterVersion="5.22.0" id="Definitions_matter_admin_opening_control" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.4.0" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="matter-admin-opening-control" isExecutable="true" name="Matter Admin Opening Control" processType="None">
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="admin-opening-preparation" name="Admin Opening Preparation" implementation="##unspecified">
      <bpmn:extensionElements>
        <zeebe:assignmentDefinition candidateGroups="= [&quot;ops_admin&quot;]" />
        <zeebe:formDefinition formKey="matter-admin-opening-intake" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="lawyer-opening-review" name="Lawyer Opening Review" implementation="##unspecified">
      <bpmn:extensionElements>
        <zeebe:assignmentDefinition assignee="= responsibleLawyerId" />
        <zeebe:formDefinition formKey="matter-admin-lawyer-review" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_1">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_1" name="Matter Open Approved">
      <bpmn:incoming>Flow_4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="admin-opening-preparation" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="admin-opening-preparation" targetRef="lawyer-opening-review" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="lawyer-opening-review" targetRef="Gateway_1" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Gateway_1" targetRef="EndEvent_1">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= decision = "approveOpen"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Gateway_1" targetRef="admin-opening-preparation">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= decision = "returnForFixes"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane bpmnElement="matter-admin-opening-control" id="BPMNPlane_1">
      <bpmndi:BPMNShape bpmnElement="StartEvent_1" id="StartEvent_1_di">
        <dc:Bounds height="36" width="36" x="173" y="102" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="admin-opening-preparation" id="admin-opening-preparation_di">
        <dc:Bounds height="80" width="120" x="270" y="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="lawyer-opening-review" id="lawyer-opening-review_di">
        <dc:Bounds height="80" width="120" x="460" y="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Gateway_1" id="Gateway_1_di" isMarkerVisible="true">
        <dc:Bounds height="50" width="50" x="650" y="95" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="EndEvent_1" id="EndEvent_1_di">
        <dc:Bounds height="36" width="36" x="790" y="102" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge bpmnElement="Flow_1" id="Flow_1_di">
        <di:waypoint x="209" y="120" />
        <di:waypoint x="270" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_2" id="Flow_2_di">
        <di:waypoint x="390" y="120" />
        <di:waypoint x="460" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_3" id="Flow_3_di">
        <di:waypoint x="580" y="120" />
        <di:waypoint x="650" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_4" id="Flow_4_di">
        <di:waypoint x="700" y="120" />
        <di:waypoint x="790" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="Flow_5" id="Flow_5_di">
        <di:waypoint x="675" y="145" />
        <di:waypoint x="675" y="240" />
        <di:waypoint x="330" y="240" />
        <di:waypoint x="330" y="160" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
