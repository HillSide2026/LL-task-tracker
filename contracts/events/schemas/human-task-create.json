{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://levinellp.ca/contracts/events/human-task-create/1.0.0",
  "title": "HumanTaskCreateEvent",
  "description": "Published to Kafka topic 'human-task-create' when a Camunda human task is created within a case workflow.",
  "version": "1.0.0",
  "type": "object",
  "required": ["id"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "description": "Camunda task ID."
    },
    "name": {
      "type": "string",
      "description": "Human-readable task name from the BPMN definition."
    },
    "description": {
      "type": "string"
    },
    "owner": {
      "type": "string",
      "description": "Task owner (Keycloak user ID or group)."
    },
    "assignee": {
      "type": "string",
      "description": "Currently assigned user."
    },
    "priority": {
      "type": "string"
    },
    "tenantId": {
      "type": "string"
    },
    "caseInstanceId": {
      "type": "string",
      "description": "The businessKey of the case this task belongs to."
    },
    "caseDefinitionId": {
      "type": "string"
    },
    "processInstanceId": {
      "type": "string"
    },
    "processDefinitionId": {
      "type": "string"
    },
    "taskDefinitionKey": {
      "type": "string",
      "description": "BPMN task definition key."
    },
    "formKey": {
      "type": "string",
      "description": "Formio form key for the task form, if any."
    },
    "created": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp when the task was created."
    },
    "due": {
      "type": "string",
      "format": "date-time"
    },
    "followUp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
