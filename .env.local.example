# .env.local — LL-task-tracker local development
#
# Used with docker-compose.local.yaml.
# Do not use these values in any environment other than local development.
# Production values live in deployments/levinellp/.env (not committed).

# ── Docker images ─────────────────────────────────────────────────────────────
CAMUNDA_DOCKER_IMAGE=camunda/camunda-bpm-platform
CAMUNDA7_VERSION=run-7.21.0

# ── Camunda ───────────────────────────────────────────────────────────────────
CAMUNDA_BASE_URL=http://camunda:8080/engine-rest
CAMUNDA_USERNAME=demo
CAMUNDA_PASSWORD=demo

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_WKS_DATABASE=matters
MONGO_DEMO_DATA_LOADER_DATABASE=matters
MONGO_CONNECTION_URL=mongodb://mongodb

# ── Keycloak ──────────────────────────────────────────────────────────────────
# Internal service URLs (container-to-container, within the Docker network).
# KEYCLOAK_URL includes /auth because docker-compose.local.yaml overrides
# the Keycloak command to serve at --http-relative-path=/auth.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=local-keycloak-admin
KEYCLOAK_URL=http://keycloak:8080/auth
KEYCLOAK_TOKEN_URL=http://keycloak:8080/auth/realms/matters/protocol/openid-connect/token

# Default user created by the bootstrap (demo-data-loader).
KEYCLOAK_DEFAULT_USER=matt
KEYCLOAK_DEFAULT_USER_PASSWORD=local-user-password
KEYCLOAK_DEFAULT_USER_EMAIL=matt@levinellp.ca
KEYCLOAK_DEFAULT_USER_FIRST_NAME=Matt
KEYCLOAK_DEFAULT_USER_LAST_NAME=Levine

# Keycloak client secrets for service accounts.
KEYCLOAK_EXTERNALTASKS_SECRET=local-externaltasks-secret
KEYCLOAK_EMAILTOCASE_SECRET=local-emailtocase-secret

# ── OPA ───────────────────────────────────────────────────────────────────────
OPA_URL=http://opa:8181/v1/data/wks/authz/allow

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minio-admin
MINIO_ROOT_PASSWORD=local-minio-password
# Internal hostname used by storage-api to reach MinIO within Docker network.
MINIO_HOST_INTERNAL=minio:9000
# External hostname used to generate pre-signed URLs for browser downloads.
# Points directly to the exposed MinIO port for local dev (no S3 subdomain needed).
MINIO_HOST_EXTERNAL=localhost:9000

# ── External task worker ──────────────────────────────────────────────────────
# Legacy WKS env var names retained for compatibility with c7-external-tasks.
WKS_CASE_API_URL=http://case-engine-rest-api:8081

# ── Runtime flags ─────────────────────────────────────────────────────────────
WEBSOCKET_ENABLED=false
DISABLE_BACKOFF_STRATEGY=true
